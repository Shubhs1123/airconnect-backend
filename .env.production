# ── AIRConnect Production Environment ──
# Copy this to .env on your server and fill in real values

# Backend port (exposed to internet)
PORT=3000

# PostgreSQL (internal Docker network — no need to change host)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=airconnect

# JWT secrets — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_64_random_chars
JWT_REFRESH_SECRET=CHANGE_ME_generate_64_random_chars

# MQTT broker credentials
MQTT_ADMIN_USER=airconnect
MQTT_ADMIN_PASS=CHANGE_ME_mqtt_password

# MQTT ports exposed on server
MQTT_PORT=1883
MQTT_TLS_PORT=8883
MQTT_WS_PORT=9001

# OpenAI (optional — for AI firmware builder)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
